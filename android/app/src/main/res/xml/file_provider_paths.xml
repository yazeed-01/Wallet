<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Allow sharing from internal app files directory -->
    <files-path name="app_files" path="." />

    <!-- Allow sharing from cache directory -->
    <cache-path name="app_cache" path="." />

    <!-- Allow sharing from external files directory if needed -->
    <external-files-path name="external_files" path="." />

    <!-- Allow sharing from external cache if needed -->
    <external-cache-path name="external_cache" path="." />
</paths>
