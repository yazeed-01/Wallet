<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow effect for Income button -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#4000E676" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Main button with vibrant emerald green -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <!-- Bright, saturated emerald green gradient -->
            <gradient
                android:startColor="#00E676"
                android:endColor="#00C853"
                android:angle="135"
                android:type="linear" />

            <!-- Fully rounded corners -->
            <corners android:radius="20dp" />

            <!-- Subtle highlight border -->
            <stroke
                android:width="1dp"
                android:color="#50FFFFFF" />
        </shape>
    </item>

</layer-list>
