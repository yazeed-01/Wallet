<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Dark charcoal/near-black glassmorphism background -->
    <gradient
        android:startColor="#CC1C1C1C"
        android:endColor="#CC2A2A2A"
        android:angle="135"
        android:type="linear" />

    <!-- Rounded corners -->
    <corners android:radius="24dp" />

    <!-- Glassmorphism border effect -->
    <stroke
        android:width="1.5dp"
        android:color="#40FFFFFF" />

    <!-- Padding -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
