<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Subtle outer glow for Expense button -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#30B85252" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Main button with muted terracotta red -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <!-- Deep terracotta/brownish-red gradient (muted) -->
            <gradient
                android:startColor="#B85252"
                android:endColor="#8B3A3A"
                android:angle="135"
                android:type="linear" />

            <!-- Fully rounded corners -->
            <corners android:radius="20dp" />

            <!-- Subtle border -->
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
        </shape>
    </item>

</layer-list>
